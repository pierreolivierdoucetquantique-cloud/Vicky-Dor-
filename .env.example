# ============================================================
# Copiez ce fichier en ".env" et remplissez vos propres valeurs.
# Ne JAMAIS committer le fichier ".env" (il contient des secrets).
# ============================================================

# --- Resend (envoi d'email) ---
# Créez un compte gratuit sur https://resend.com puis générez une clé API.
RESEND_API_KEY=re_VOTRE_CLE_ICI

# Adresse d'expédition des emails.
# Si votre domaine est vérifié sur Resend (Domains > vickydore.com > Verified),
# utilisez une adresse @vickydore.com (ex : reservation@vickydore.com).
# N'importe quelle adresse sur ce domaine fonctionne, même si elle ne
# correspond pas à une vraie boîte mail.
# Tant que le domaine n'est PAS vérifié, Resend bloque silencieusement
# l'envoi à toute adresse autre que celle de votre propre compte Resend —
# utilisez alors "onboarding@resend.dev" pour les tests.
# ⚠️ Après toute modification de cette valeur, le serveur doit être
# redémarré (Ctrl+C puis "node server.js") pour que le changement soit pris en compte.
EMAIL_FROM=reservation@vickydore.com

# Adresse de Vicky (reçoit une copie de chaque nouvelle réservation)
ADMIN_EMAIL=message_VD@hotmail.com

# URL de base du site, utilisée pour construire les liens envoyés par courriel
# (ex : lien de réinitialisation de mot de passe). En local, laissez la valeur
# par défaut ci-dessous. En production, mettez votre vraie adresse (ex :
# https://www.vickydore.com), sans slash à la fin.
SITE_URL=http://localhost:3000

# Mot de passe pour le compte admin de Vicky (à changer !)
ADMIN_PASSWORD=changez-moi-123

# Clé secrète utilisée pour signer les cookies de session.
# Mettez n'importe quelle longue chaîne aléatoire.
SESSION_SECRET=remplacez-par-une-longue-chaine-aleatoire-unique

# Port local du serveur
PORT=3000

# --- Stockage persistant (base de données + images téléversées) ---
# IMPORTANT EN PRODUCTION (Render ou tout hébergeur similaire) : le disque
# du service web est éphémère et est remis à zéro à chaque redéploiement.
# Pour que les réservations, disponibilités, comptes clients et bannières
# promo ne disparaissent JAMAIS après un déploiement, vous devez :
#   1. Sur Render : Service web -> onglet "Disks" -> ajouter un disque
#      persistant (1 Go suffit largement pour ce projet).
#   2. Choisir un point de montage, par exemple : /data
#   3. Régler DATA_DIR ci-dessous (ou dans les variables d'environnement
#      Render) sur ce même chemin : /data
# En local (sur votre ordinateur), laissez cette ligne commentée ou vide :
# le serveur utilisera alors un dossier "data" à côté du code, ce qui est
# suffisant pour le développement.
# DATA_DIR=/data

# --- Vicky7up (synchronisation avec l'app mobile, générée via Emergent) ---
# URL de base du backend Vicky7up (sans slash à la fin).
VICKY7UP_BASE_URL=https://appointment-hub-796.preview.emergentagent.com
# Clé secrète du webhook Vicky7up — NE JAMAIS exposer côté navigateur.
VICKY7UP_WEBHOOK_KEY=vk_VOTRE_CLE_ICI
# Clé attendue sur les webhooks ENTRANTS depuis Vicky7up (sens app -> site).
# Doit correspondre EXACTEMENT à VICKYDORE_WEBHOOK_KEY dans le .env de Vicky7up.
# Clé attendue sur les webhooks ENTRANTS depuis Vicky7up (sens app -> site),
# utilisée à la fois par /api/webhook/client et /api/webhook/vicky7up.
# Doit correspondre EXACTEMENT à VICKYDORE_WEBHOOK_KEY dans le .env de Vicky7up.
VICKY7UP_TO_SITE_KEY=vd_mpbbntA_3V_XX648iJq7cvxGhCDnpmwT1WsCEmT-BITTPEINuq-oaw
