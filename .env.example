# ============================================================
# Copiez ce fichier en ".env" et remplissez vos propres valeurs.
# Ne JAMAIS committer le fichier ".env" (il contient des secrets).
# ============================================================

# --- Resend (envoi d'email) ---
# Créez un compte gratuit sur https://resend.com puis générez une clé API.
RESEND_API_KEY=re_VOTRE_CLE_ICI

# Adresse d'expédition des emails.
# En mode test Resend, utilisez "onboarding@resend.dev" tant que vous
# n'avez pas vérifié votre propre domaine.
EMAIL_FROM=onboarding@resend.dev

# Adresse de Vicky (reçoit une copie de chaque nouvelle réservation)
ADMIN_EMAIL=Vicky_dore@hotmail.com

# URL de base du site, utilisée pour construire les liens envoyés par courriel
# (ex : lien de réinitialisation de mot de passe). En local, laissez la valeur
# par défaut ci-dessous. En production, mettez votre vraie adresse (ex :
# https://www.vickydore.com), sans slash à la fin.
SITE_URL=http://localhost:3000

# Mot de passe pour le compte admin de Vicky (à changer !)
ADMIN_PASSWORD=changez-moi-123

# Clé secrète utilisée pour signer les cookies de session.
# Mettez n'importe quelle longue chaîne aléatoire.
SESSION_SECRET=remplacez-par-une-longue-chaine-aleatoire-unique

# Port local du serveur
PORT=3000
